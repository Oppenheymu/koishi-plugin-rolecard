{
  "desc": "别里科夫触发词配置。matchMode=include 表示消息包含任一关键词即命中；按 group 优先级(priority 越小越优先)匹配，命中后从 words.json 中对应 tag 的语录里随机取一条。random 为概率随机触发，cooldown 为冷却秒数，防止刷屏。",
  "groups": [
    {
      "tag": "proposal",
      "name": "提议与搞事",
      "desc": "群友提议做新事情时泼冷水，效果最佳",
      "matchMode": "include",
      "priority": 1,
      "keywords": [
        "要不", "提议", "整一个", "搞个", "计划", "打算", "准备",
        "去不去", "面基", "一起去", "约", "组织", "活动", "报名",
        "试试", "能不能", "可以不", "行不行", "凑个", "开个"
      ]
    },
    {
      "tag": "emotional",
      "name": "情绪波动与违规边缘",
      "desc": "群友情绪激昂或聊敏感话题，别里科夫胆小受惊",
      "matchMode": "include",
      "priority": 2,
      "keywords": [
        "笑死", "哈哈", "卧槽", "牛逼", "狂", "冲", "节奏", "举报",
        "离谱", "绝了", "破防", "无语", "炸裂", "刺激", "敢说",
        "牛批", "666", "牛啊", "牛逼啊", "疯了", "逆天"
      ]
    },
    {
      "tag": "rules",
      "name": "规章制度与日常通知",
      "desc": "群主发公告或讨论规则时，搬出教条",
      "matchMode": "include",
      "priority": 3,
      "keywords": [
        "通知", "公告", "群规", "放假", "开会", "新规定", "规定",
        "规则", "禁", "禁止", "处罚", "踢", "禁言", "管理", "群主",
        "解散", "迁移", "审核"
      ]
    },
    {
      "tag": "distancing",
      "name": "撇清关系与甩锅",
      "desc": "群里起纷争、互相甩锅或被牵连时，急于划清界限",
      "matchMode": "include",
      "priority": 4,
      "keywords": [
        "别里科夫", "怪你", "赖你", "都怪", "谁干的", "你弄的",
        "怪我", "不怪我", "跟我没关系", "你的锅", "谁的锅",
        "甩锅", "背锅", "怪谁", "赖谁"
      ]
    }
  ],
  "random": {
    "enabled": true,
    "probability": 0.03,
    "pool": "all",
    "desc": "任意消息 3% 概率随机触发，pool=all 表示从全部语录中随机取一条"
  },
  "cooldown": 60
}
